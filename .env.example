# TickTick（滴答清单）- 必填
# 滴答清单 v2_base_url 需为 https://api.dida365.com/api/v2/
PYTICKTICK_V2_USERNAME=your_email@example.com
PYTICKTICK_V2_PASSWORD=your_password

# 钉钉 - 必填（推送到钉钉时）
# 需在钉钉开放平台创建应用并申请「管理员工日志数据」权限
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_USER_ID=your_userid
DINGTALK_CORP_ID=your_corpid

# 钉钉 - 可选
DINGTALK_TEMPLATE_NAME=日报
DINGTALK_DD_FROM=ticktick
